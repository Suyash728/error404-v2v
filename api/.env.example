# Supabase project (Settings -> API). User JWTs are verified against the
# project's public JWKS (SUPABASE_URL + /auth/v1/.well-known/jwks.json), not
# a shared secret, so no JWT secret env var is needed here.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers, consumed only by services/llm_client.py
GEMINI_API_KEY=
GROQ_API_KEY=
