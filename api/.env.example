# Supabase project (Settings -> API). User JWTs are verified against the
# project's public JWKS (SUPABASE_URL + /auth/v1/.well-known/jwks.json), not
# a shared secret, so no JWT secret env var is needed here.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers, consumed only by services/llm_client.py
GEMINI_API_KEY=
GROQ_API_KEY=

# Google Calendar sync (services/gcal.py). Client ID/secret come from a
# Google Cloud OAuth 2.0 Client (type: Web application) with the Calendar
# API enabled; GOOGLE_REDIRECT_URI must exactly match a redirect URI
# registered on that client (e.g. http://localhost:8000/calendar/oauth/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback

# Where to send the browser after the OAuth callback finishes.
FRONTEND_URL=http://localhost:3000

# Fernet key encrypting stored refresh tokens (core/crypto.py). Generate
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GCAL_TOKEN_ENCRYPTION_KEY=
